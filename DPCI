<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>The Delaware Peace Crane Initiative | Mind of Kasmira</title>
<meta name="description" content="A facilitated healing arts workshop where participants fold origami cranes, write peace messages, and send them into a global exchange network active in 150+ countries.">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=Lato:wght@300;400;700;900&display=swap" rel="stylesheet">
<style>
  :root {
    --emerald: #017775;
    --emerald-dark: #015F5D;
    --sapphire: #2A4D98;
    --gold: #DAA137;
    --gold-light: #F0C060;
    --violet: #968ACF;
    --violet-light: #B8ADE0;
    --cream: #F2EDE4;
    --brown: #2C2416;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Lato', sans-serif;
    color: var(--brown);
    background: linear-gradient(180deg, #ffffff 0%, #fffdf8 40%, var(--cream) 100%);
    line-height: 1.6;
  }

  a { color: inherit; }

  .wrap {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ── TOP STRIPE ── */
  .de-stripe {
    height: 5px;
    background: linear-gradient(90deg, #003399 50%, #FFD700 50%);
  }

  /* ── HERO ── */
  .hero {
    position: relative;
    padding: 64px 0 40px;
    overflow: hidden;
  }

  .hero-crane {
    position: absolute;
    top: -40px;
    right: -60px;
    width: 320px;
    opacity: 0.16;
    pointer-events: none;
  }

  .eyebrow {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--emerald);
    margin-bottom: 14px;
  }

  h1 {
    font-family: 'Playfair Display', serif;
    font-weight: 900;
    font-size: clamp(34px, 6vw, 54px);
    line-height: 1.08;
    color: var(--brown);
    max-width: 11ch;
  }

  h1 em {
    font-style: italic;
    color: var(--emerald-dark);
    font-weight: 700;
  }

  .tagline {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 19px;
    color: var(--sapphire);
    margin-top: 18px;
    max-width: 32ch;
  }

  .hero-quote {
    margin-top: 32px;
    padding-left: 18px;
    border-left: 3px solid var(--gold);
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 16px;
    color: var(--brown);
    max-width: 40ch;
  }

  /* ── CTA BUTTON ── */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    background: var(--emerald-dark);
    color: white;
    font-family: 'Lato', sans-serif;
    font-weight: 700;
    font-size: 15px;
    letter-spacing: 0.01em;
    text-decoration: none;
    padding: 15px 30px;
    border-radius: 100px;
    margin-top: 34px;
    box-shadow: 0 4px 14px rgba(1, 95, 93, 0.25);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 18px rgba(1, 95, 93, 0.32);
  }
  .btn svg { width: 16px; height: 16px; flex-shrink: 0; }

  /* ── SECTION GENERAL ── */
  section {
    padding: 56px 0;
    border-top: 1px solid rgba(1, 119, 117, 0.14);
  }

  .section-label {
    font-size: 11.5px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--sapphire);
    margin-bottom: 16px;
  }

  h2 {
    font-family: 'Playfair Display', serif;
    font-size: 28px;
    color: var(--emerald-dark);
    margin-bottom: 18px;
    max-width: 22ch;
  }

  p.lede {
    font-size: 17px;
    max-width: 56ch;
    color: #3A3020;
  }

  /* ── WHAT IT IS ── */
  .what-grid {
    display: flex;
    gap: 14px;
    margin-top: 30px;
  }

  .what-card {
    flex: 1;
    background: rgba(255,255,255,0.7);
    border-radius: 10px;
    padding: 18px;
    border-top: 3px solid var(--emerald);
  }
  .what-card:nth-child(2) { border-top-color: var(--sapphire); }
  .what-card:nth-child(3) { border-top-color: var(--gold); }

  .what-card h3 {
    font-family: 'Playfair Display', serif;
    font-size: 15.5px;
    font-weight: 700;
    color: var(--emerald-dark);
    margin-bottom: 6px;
  }
  .what-card:nth-child(2) h3 { color: var(--sapphire); }
  .what-card:nth-child(3) h3 { color: #8B6010; }

  .what-card p {
    font-size: 13.5px;
    color: #4A4038;
  }

  /* ── HOW IT WORKS ── */
  .steps {
    margin-top: 30px;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .step {
    display: flex;
    gap: 20px;
    padding: 18px 0;
    border-bottom: 1px dashed rgba(1, 119, 117, 0.2);
  }
  .step:last-child { border-bottom: none; }

  .step-num {
    font-family: 'Playfair Display', serif;
    font-weight: 900;
    font-size: 22px;
    color: var(--gold);
    width: 36px;
    flex-shrink: 0;
  }

  .step-body h4 {
    font-family: 'Playfair Display', serif;
    font-size: 17px;
    font-weight: 700;
    color: var(--brown);
    margin-bottom: 3px;
  }
  .step-body p {
    font-size: 14.5px;
    color: #4A4038;
  }

  /* ── PARTNER STRIP ── */
  .partner-strip {
    background: rgba(1, 119, 117, 0.07);
    border-radius: 12px;
    padding: 26px 28px;
    margin-top: 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
  }

  .partner-text {
    font-size: 14.5px;
    color: var(--brown);
    max-width: 44ch;
  }
  .partner-text strong { color: var(--emerald-dark); }

  .partner-link {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-weight: 700;
    font-size: 14px;
    color: var(--emerald-dark);
    text-decoration: none;
    white-space: nowrap;
    border-bottom: 1.5px solid var(--gold);
    padding-bottom: 2px;
  }
  .partner-link:hover { color: var(--sapphire); }

  /* ── BOOK SECTION ── */
  .book-section {
    text-align: center;
    padding: 64px 0 70px;
  }

  .book-section h2 {
    margin: 0 auto 12px;
  }

  .book-section p.lede {
    margin: 0 auto;
  }

  .founding-note {
    display: inline-block;
    margin-top: 22px;
    background: var(--gold);
    color: var(--brown);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 6px 16px;
    border-radius: 100px;
  }

  .book-section .btn {
    display: inline-flex;
    margin-top: 26px;
  }

  /* ── FOOTER ── */
  footer {
    border-top: 1px solid rgba(1, 119, 117, 0.14);
    padding: 32px 0 44px;
    text-align: center;
  }

  .footer-logo {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 15px;
    color: var(--sapphire);
  }
  .footer-logo strong {
    font-style: normal;
    font-family: 'Lato', sans-serif;
    color: var(--brown);
    letter-spacing: 0.04em;
  }
  .footer-sub {
    font-size: 11px;
    color: #8B7355;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-top: 4px;
  }
  .footer-links {
    margin-top: 16px;
    font-size: 13px;
  }
  .footer-links a {
    color: var(--emerald-dark);
    text-decoration: none;
    margin: 0 8px;
  }
  .footer-links a:hover { text-decoration: underline; }

  /* ── RESPONSIVE ── */
  @media (max-width: 640px) {
    .what-grid { flex-direction: column; }
    .hero-crane { width: 200px; top: -20px; right: -40px; }
    .partner-strip { flex-direction: column; align-items: flex-start; }
  }
</style>
</head>
<body>

<div class="de-stripe"></div>

<!-- ═══════════ HERO ═══════════ -->
<header class="hero">
  <div class="wrap">
    <div class="eyebrow">Mind of Kasmira presents</div>
    <h1>The Delaware <em>Peace Crane Initiative</em></h1>
    <p class="tagline">Because your inner child has something to say.</p>
    <p class="hero-quote">"Delaware's voices will travel the world. The world will write back."</p>
